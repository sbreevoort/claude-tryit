{
  "name": "react-app",
  "private": true,
  "version": "0.0.0",
  "type": "module",
"scripts": {
      "dev": "vite",
      "start": "concurrently --names \"React,Mocks\" \"pnpm dev\" \"pnpm mocks\"",
      "start:backend": "pnpm run generate:api && vite --mode=backend",
      "mocks": "nodemon --ext ts,tsx --watch mock-server --exec \"ts-node --project tsconfig.mocks.json ./mock-server/mock-server.ts\"",
      "mocks:playwright": "pnpm run mocks -- --context=playwright",
      "build": "pnpm run generate:api && tsc -b && vite build",
      "lint": "eslint .",
      "preview": "vite preview",
      "generate:api": "orval"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.74.4",
    "axios": "^1.8.4",
    "clsx": "^2.1.1",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-error-boundary": "^5.0.0",
    "react-router-dom": "^7.5.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.25.0",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@vitejs/plugin-react": "^4.4.1",
    "concurrently": "^9.2.1",
    "eslint": "^9.25.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.19",
    "globals": "^16.0.0",
    "nodemon": "^3.1.14",
    "orval": "^8.8.0",
    "ts-node": "^10.9.2",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.30.1",
    "vite": "^6.3.1"
  }
}
